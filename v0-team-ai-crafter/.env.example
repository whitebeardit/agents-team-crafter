# URL pública da app Next (links de convite /invite/...); use o mesmo host que abre no browser (localhost vs 127.0.0.1 são origens diferentes).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Base URL do BFF (inclui /api/v1)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

