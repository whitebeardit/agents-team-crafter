# Copie para .env na raiz (usado pelo docker compose e pelo seed).
# Connection string do MongoDB Atlas (Network Access: permitir o IP de onde corre o Docker/host).

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority

# Em produção (Coolify), defina JWT_SECRET na UI — não use o default do docker-compose.
# JWT_SECRET=coloque-uma-string-com-pelo-menos-32-caracteres

# Opcional — admin global por email (virgulas) alinhado com backend/.env.example
# PLATFORM_ADMIN_EMAILS=admin@whitebeard.dev

# --- Coolify / produção ---
# Não defina NEXT_PUBLIC_* com localhost — o valor entra no build do Next; o login no browser
# chamaria http://localhost:3001 e falha. Use os URLs HTTPS públicos (api.* + app).
# Rebuild obrigatório do frontend após alterar NEXT_PUBLIC_*.
#
# @vercel/analytics só carrega com NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=true (Vercel).
# Em Docker/Coolify deixe false ou omita — evita 404 em /_vercel/insights/script.js.
#
# Defaults de produção (já no docker-compose; sobrescreva só se necessário):
# FRONTEND_PORT=3002
# BACKEND_PORT=3001
# PORT=3001
# REDIS_PORT=6379
# CORS_ORIGIN=https://myteams.whitebeard.dev,https://myteams.whitebeard.dev:3002
# PUBLIC_API_BASE_URL=https://api.myteams.whitebeard.dev
# NEXT_PUBLIC_APP_URL=https://myteams.whitebeard.dev
# NEXT_PUBLIC_API_URL=https://api.myteams.whitebeard.dev/api/v1
# NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
# ALLOW_LOCALHOST_API=false

# --- Desenvolvimento local (docker compose na máquina com API em localhost) ---
# O build da imagem falha se NEXT_PUBLIC_API_URL tiver localhost sem isto:
# ALLOW_LOCALHOST_API=true
# CORS_ORIGIN=http://localhost:3002
# PUBLIC_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_APP_URL=http://localhost:3002
# NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
