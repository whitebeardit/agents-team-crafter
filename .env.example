# Copie para .env na raiz (usado pelo docker compose e pelo seed).
# Connection string do MongoDB Atlas (Network Access: permitir o IP de onde corre o Docker/host).

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority

# Opcional — senão o compose usa um default só para desenvolvimento local
# JWT_SECRET=coloque-uma-string-com-pelo-menos-32-caracteres

# Opcional — admin global por email (virgulas) alinhado com backend/.env.example
# PLATFORM_ADMIN_EMAILS=admin@whitebeard.dev

# --- Docker Compose (portas no host + CORS / URLs públicas) ---
# Se a porta 3000 já estiver em uso (ex.: outro app no Coolify), mude só o bind do host:
# FRONTEND_PORT=3002
# BACKEND_PORT=3001
# REDIS_PORT=6379
#
# Origens permitidas no browser (várias separadas por vírgula). Em produção use o URL real do frontend:
# CORS_ORIGIN=https://app.seudominio.com,https://www.seudominio.com
#
# Base pública da API (links absolutos / galeria). Deve bater com o que o browser usa:
# PUBLIC_API_BASE_URL=https://api.seudominio.com
#
# Build do Next.js — obrigatório alinhar com o deploy (Coolify costuma dar domínio próprio):
# NEXT_PUBLIC_APP_URL=https://app.seudominio.com
# NEXT_PUBLIC_API_URL=https://api.seudominio.com/api/v1
