    "@chat-adapter/slack": "^4.23.0",
    "@chat-adapter/state-memory": "^4.23.0",
    "@chat-adapter/state-redis": "^4.23.0",
    "@chat-adapter/teams": "^4.23.0",
    "@chat-adapter/telegram": "^4.23.0",
    "@chat-adapter/whatsapp": "^4.23.0",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.4.0",
    "@openai/agents": "^0.8.1",
    "bcrypt": "^5.1.1",
    "chat": "^4.23.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.3",
    "nodemailer": "^8.0.4",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "zod": "^4.3.6"
