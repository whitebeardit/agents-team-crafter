    "verify:team-channels": "tsx scripts/verify-team-channels.ts",
    "telegram:set-webhook": "tsx scripts/telegram-set-webhook.ts"
  },
  "dependencies": {
    "@chat-adapter/discord": "^4.23.0",
    "@chat-adapter/gchat": "^4.23.0",
    "@chat-adapter/github": "^4.23.0",
