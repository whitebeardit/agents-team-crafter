NODE_ENV=development
PORT=3001
# Atlas (recomendado) ou Mongo local: mongodb://127.0.0.1:27017/teamagents
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE
JWT_SECRET=change-me-in-production-min-32-chars-long!!
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
# Uma origem ou varias separadas por virgula. Inclua 127.0.0.1 se abrir o Next por http://127.0.0.1:3000 (e diferente de localhost para o browser).
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://10.0.0.148:3000

# Admin global por email (lista separada por virgula) se o documento Mongo nao tiver isPlatformAdmin: true.
# Ex.: PLATFORM_ADMIN_EMAILS=admin@whitebeard.dev
# PLATFORM_ADMIN_EMAILS=

# --- Multi-tenant (producao) ---
# Chave mestra 64 hex (32 bytes). Com NODE_ENV=production o BFF recusa arrancar sem ela (validacao em loadEnv).
# Obrigatoria para gravar segredos por workspace e por canal.
# ENCRYPTION_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
#
# Integracoes por tenant: UI em Configuracoes > Integracoes (GET/PUT /settings/workspace/integrations).
# Nao use as variaveis abaixo para credenciais de clientes em deploy multi-tenant.

# --- OpenAI (runtime de agentes + planner de times em POST /team-plans) ---
# Sem chave no workspace (Integracoes), o backend usa OPENAI_API_KEY daqui (dev/demo).
# OPENAI_API_KEY=sk-...
# Modelo opcional para o planner JSON (padrao: gpt-4o-mini).
# OPENAI_TEAM_PLAN_MODEL=gpt-4o-mini
#
# Tracing cloud do @openai/agents (exportador process-wide). Em multi-tenant com BYOK só em banco,
# definir 1 evita avisos sem precisar de OPENAI_API_KEY global para traces. Docker: ver docker-compose.yaml.
# OPENAI_AGENTS_DISABLE_TRACING=1

# --- Team plan execute: bind automatico de business tools (internal_action) ---
# 0 = desligado (default). 1 = ao executar POST /team-plans/:id/execute cria/reutiliza WorkspaceToolDefinition e preenche customToolDefinitionIds nos agentes novos (requiredTools / requiredPacks).
# TEAM_PLAN_AUTO_BIND_TOOLS=0

# --- Apenas demo local Slack (depois de migrar: Slack por workspace em Integracoes ou PUT /channels/:id/secrets) ---
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=

# Apos `npm run seed` no diretorio backend, use no login do frontend:
# Email: admin@whitebeard.dev
# Senha: Admin123!

# --- Galeria de imagens por time (ferramenta image_generation) ---
# Raiz no disco. Por omissao: ./data/gallery (relativo ao cwd do backend).
# MEDIA_GALLERY_ROOT=data/gallery
# URL publica do BFF para links na resposta da tool (opcional; sem isto, mostra path relativo /api/v1/...).
# PUBLIC_API_BASE_URL=http://localhost:3001
