NODE_ENV=development
PORT=3001
# Atlas (recomendado) ou Mongo local: mongodb://127.0.0.1:27017/teamagents
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE
JWT_SECRET=change-me-in-production-min-32-chars-long!!
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
# Uma origem ou varias separadas por virgula (ex.: dev em localhost e pelo IP da LAN).
CORS_ORIGIN=http://localhost:3000,http://10.0.0.148:3000

# Admin global por email (lista separada por virgula) se o documento Mongo nao tiver isPlatformAdmin: true.
# Ex.: PLATFORM_ADMIN_EMAILS=admin@whitebeard.dev
# PLATFORM_ADMIN_EMAILS=

# --- Multi-tenant (producao) ---
# Chave mestra 64 hex (32 bytes). Obrigatoria para gravar segredos por workspace e por canal.
# ENCRYPTION_MASTER_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
#
# Integracoes por tenant: UI em Configuracoes > Integracoes (GET/PUT /settings/workspace/integrations).
# Nao use as variaveis abaixo para credenciais de clientes em deploy multi-tenant.

# --- OpenAI (runtime de agentes + planner de times em POST /team-plans) ---
# Sem chave no workspace (Integracoes), o backend usa OPENAI_API_KEY daqui (dev/demo).
# OPENAI_API_KEY=sk-...
# Modelo opcional para o planner JSON (padrao: gpt-4o-mini).
# OPENAI_TEAM_PLAN_MODEL=gpt-4o-mini

# --- Apenas demo local Slack (depois de migrar: Slack por workspace em Integracoes ou PUT /channels/:id/secrets) ---
# SLACK_SIGNING_SECRET=
# SLACK_BOT_TOKEN=

# Apos `npm run seed` no diretorio backend, use no login do frontend:
# Email: admin@whitebeard.dev
# Senha: Admin123!
